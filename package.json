		"@turf/nearest-point-on-line": "^7.2.0",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"html-to-image": "^1.11.13",
		"maplibre-gl": "^5.0.0",
		"rbush": "^4.0.1"
	},
	"packageManager": "pnpm@10.30.3",
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
	}
