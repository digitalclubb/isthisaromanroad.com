{
	"name": "isthisaromanroad",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome check .",
		"format": "biome format --write .",
		"fix": "biome check --write .",
		"data:build": "node --experimental-strip-types scripts/build-roads.ts",
		"icons:build": "node --experimental-strip-types scripts/generate-icons.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-vercel": "^5.5.2",
		"@sveltejs/kit": "^2.15.1",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@types/geojson": "^7946.0.15",
		"@types/node": "^22.10.5",
		"@types/proj4": "^2.19.0",
		"@types/rbush": "^4.0.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"proj4": "^2.20.8",
		"svelte": "^5.16.0",
		"svelte-check": "^4.1.1",
		"typescript": "^5.7.2",
		"vite": "^6.0.7"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/cormorant-garamond": "^5.2.11",
